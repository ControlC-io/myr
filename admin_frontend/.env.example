# Admin Frontend Environment Variables (example)
# Variables must start with VITE_ to be exposed to the frontend.

# When running behind nginx (recommended), you can usually leave this empty
# and rely on relative /api calls to the same origin (http://localhost:8080).
# For direct dev against the backend (without nginx), set:
# VITE_API_URL=http://localhost:3000
VITE_API_URL=

# Must match ADMIN_SECRET in the backend (.env at project root).
VITE_ADMIN_SECRET=change_me_admin_secret

